# Data files are re-generated by the transcription pipeline without changing
# filenames, so we can't cache them forever — but repeat visitors shouldn't
# re-download the whole 12MB corpus on every single page load either.
# stale-while-revalidate lets the browser serve the cached copy instantly
# and quietly fetch a fresh one in the background.

/data/shard-*.json
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/data/episodes.json
  Cache-Control: public, max-age=300, stale-while-revalidate=3600

/data/stats.json
  Cache-Control: public, max-age=300, stale-while-revalidate=3600

/data/taglines.json
  Cache-Control: public, max-age=300, stale-while-revalidate=3600
